generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// 迭代 042/046：状态字段从 String 迁移为原生 Enum，获得编译时类型安全
enum SessionStatus {
  active
  diagnosing
  completed
  archived
}

enum TeachingMode {
  warm
  strict
  interviewer
}

// 迭代 051：学/固/验三阶段归属（与 teachingMode 的对话风格区分，spec §1）
enum ActiveMode {
  learning
  review
  interview
}

enum NodeStatus {
  not_started
  in_progress
  mastered
}

enum MessageRole {
  tutor
  learner
  system
}

enum MessageType {
  text
  quiz
  quiz_response
  assessment
  system
}

enum MessageStatus {
  sending
  processing
  completed
  failed
}

enum SourceType {
  pdf
  markdown
  video
}

// 迭代 009：资料处理状态机，驱动 RAG 异步流水线的 UI 反馈
enum SourceStatus {
  pending
  processing
  ready
  failed
}

model User {
  id         String          @id @default(cuid()) @db.Text
  name       String          @db.Text
  sessions   Session[]
  sources    Source[]
  profile    LearnerProfile?
  llmConfigs LlmConfig[]
  createdAt  DateTime        @default(now())
}

model Source {
  id        String     @id @default(cuid()) @db.Text
  userId    String     @db.Text
  user      User       @relation(fields: [userId], references: [id])
  title     String     @db.Text
  type      SourceType
  content   String?    @db.Text
  fileUrl   String?    @db.Text
  checksum  String?      @db.Text
  externalUrl String?    @db.Text
  status    SourceStatus @default(pending)
  sessions  Session[]
  chunks    DocumentChunk[]
  createdAt DateTime     @default(now())

  @@index([userId])
}

// 迭代 009：文档分块 + 向量存储（pgvector）。embedding 字段 Prisma 不原生支持，用 Unsupported 声明，retrieval service 经 raw SQL 检索
model DocumentChunk {
  id         String   @id @default(cuid()) @db.Text
  sourceId   String   @db.Text
  source     Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String   @db.Text
  tokenCount Int
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now())

  @@index([sourceId])
}

model Session {
  id           String        @id @default(cuid()) @db.Text
  userId       String        @db.Text
  user         User          @relation(fields: [userId], references: [id])
  topic        String        @db.Text
  sourceId     String?       @db.Text
  source       Source?       @relation(fields: [sourceId], references: [id])
  status       SessionStatus @default(active)
  summary      Json?
  teachingMode TeachingMode  @default(warm)
  activeMode   ActiveMode    @default(learning) // 迭代 051：当前学/固/验模式（spec §7）
  llmConfigId  String?       @db.Text
  llmConfig    LlmConfig?    @relation(fields: [llmConfigId], references: [id])
  roadmap      Roadmap?
  messages     Message[]
  checkpoints  Checkpoint[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, status])
  @@index([userId, updatedAt])
}

model Roadmap {
  id        String  @id @default(cuid()) @db.Text
  sessionId String  @unique @db.Text
  session   Session @relation(fields: [sessionId], references: [id])
  nodes     Node[]
  version   Int     @default(1)
}

model Node {
  id           String     @id @default(cuid()) @db.Text
  roadmapId    String     @db.Text
  roadmap      Roadmap    @relation(fields: [roadmapId], references: [id])
  index        Int
  title        String     @db.Text
  description  String     @db.Text
  status       NodeStatus @default(not_started)
  masteryScore Int        @default(0)
  reviewLog    Json?
  masteredAt   DateTime?
  // 迭代 051：间隔重复持久化（spec §3.4 / §7.1）。@default 兜底老数据，无需单独迁移脚本
  memoryStrength  Float     @default(1.0) // 老节点视为刚掌握、强度满
  lastReviewedAt  DateTime? // 未复习过
  nextReviewAt    DateTime? // null 表示逾期，进入复习模式优先呈现
  reviewInterval  Int       @default(1) // 当前复习间隔（天），首次 1d

  @@index([roadmapId, index])
  @@index([roadmapId, status])
}

model Message {
  id        String        @id @default(cuid()) @db.Text
  sessionId String        @db.Text
  session   Session       @relation(fields: [sessionId], references: [id])
  role      MessageRole
  type      MessageType
  content   String        @db.Text
  status    MessageStatus @default(completed)
  metadata  Json?
  hidden    Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model Checkpoint {
  id        String   @id @default(cuid()) @db.Text
  sessionId String   @db.Text
  session   Session  @relation(fields: [sessionId], references: [id])
  graphNode String   @db.Text
  state     Json
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model LearnerProfile {
  id                    String   @id @default(cuid()) @db.Text
  userId                String   @unique @db.Text
  user                  User     @relation(fields: [userId], references: [id])
  learningStyle         Json?
  strengths             Json?
  weaknesses            Json?
  misconceptionPatterns Json?
  sessionsSummary       Json?
  updatedAt             DateTime @updatedAt
}

model LlmConfig {
  id           String    @id @default(cuid()) @db.Text
  userId       String    @db.Text
  user         User      @relation(fields: [userId], references: [id])
  provider     String    @db.Text
  encryptedKey String    @db.Text
  baseUrl      String?   @db.Text
  defaultModel String    @db.Text
  label        String?   @db.Text
  isDefault    Boolean   @default(false)
  source       String    @default("user") @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([userId])
}
