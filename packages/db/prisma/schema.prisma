generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 迭代 042/046：状态字段从 String 迁移为原生 Enum，获得编译时类型安全
enum SessionStatus {
  active
  diagnosing
  completed
  archived
}

enum TeachingMode {
  warm
  strict
  interviewer
}

enum NodeStatus {
  not_started
  in_progress
  mastered
}

enum MessageRole {
  tutor
  learner
  system
}

enum MessageType {
  text
  quiz
  quiz_response
  assessment
  system
}

enum MessageStatus {
  sending
  processing
  completed
  failed
}

enum SourceType {
  pdf
  markdown
}

model User {
  id         String          @id @default(cuid()) @db.Text
  name       String          @db.Text
  sessions   Session[]
  sources    Source[]
  profile    LearnerProfile?
  llmConfigs LlmConfig[]
  createdAt  DateTime        @default(now())
}

model Source {
  id        String     @id @default(cuid()) @db.Text
  userId    String     @db.Text
  user      User       @relation(fields: [userId], references: [id])
  title     String     @db.Text
  type      SourceType
  content   String?    @db.Text
  fileUrl   String?    @db.Text
  checksum  String?    @db.Text
  sessions  Session[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model Session {
  id           String        @id @default(cuid()) @db.Text
  userId       String        @db.Text
  user         User          @relation(fields: [userId], references: [id])
  topic        String        @db.Text
  sourceId     String?       @db.Text
  source       Source?       @relation(fields: [sourceId], references: [id])
  status       SessionStatus @default(active)
  summary      Json?
  teachingMode TeachingMode  @default(warm)
  llmConfigId  String?       @db.Text
  llmConfig    LlmConfig?    @relation(fields: [llmConfigId], references: [id])
  roadmap      Roadmap?
  messages     Message[]
  checkpoints  Checkpoint[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, status])
  @@index([userId, updatedAt])
}

model Roadmap {
  id        String  @id @default(cuid()) @db.Text
  sessionId String  @unique @db.Text
  session   Session @relation(fields: [sessionId], references: [id])
  nodes     Node[]
  version   Int     @default(1)
}

model Node {
  id           String     @id @default(cuid()) @db.Text
  roadmapId    String     @db.Text
  roadmap      Roadmap    @relation(fields: [roadmapId], references: [id])
  index        Int
  title        String     @db.Text
  description  String     @db.Text
  status       NodeStatus @default(not_started)
  masteryScore Int        @default(0)
  reviewLog    Json?
  masteredAt   DateTime?

  @@index([roadmapId, index])
  @@index([roadmapId, status])
}

model Message {
  id        String        @id @default(cuid()) @db.Text
  sessionId String        @db.Text
  session   Session       @relation(fields: [sessionId], references: [id])
  role      MessageRole
  type      MessageType
  content   String        @db.Text
  status    MessageStatus @default(completed)
  metadata  Json?
  hidden    Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model Checkpoint {
  id        String   @id @default(cuid()) @db.Text
  sessionId String   @db.Text
  session   Session  @relation(fields: [sessionId], references: [id])
  graphNode String   @db.Text
  state     Json
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model LearnerProfile {
  id                    String   @id @default(cuid()) @db.Text
  userId                String   @unique @db.Text
  user                  User     @relation(fields: [userId], references: [id])
  learningStyle         Json?
  strengths             Json?
  weaknesses            Json?
  misconceptionPatterns Json?
  sessionsSummary       Json?
  updatedAt             DateTime @updatedAt
}

model LlmConfig {
  id           String    @id @default(cuid()) @db.Text
  userId       String    @db.Text
  user         User      @relation(fields: [userId], references: [id])
  provider     String    @db.Text
  encryptedKey String    @db.Text
  baseUrl      String?   @db.Text
  defaultModel String    @db.Text
  label        String?   @db.Text
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([userId])
}
