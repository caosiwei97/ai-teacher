generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(cuid()) @db.Text
  name      String          @db.Text
  sessions  Session[]
  sources   Source[]
  profile   LearnerProfile?
  createdAt DateTime        @default(now())
}

model Source {
  id        String    @id @default(cuid()) @db.Text
  userId    String    @db.Text
  user      User      @relation(fields: [userId], references: [id])
  title     String    @db.Text
  type      String    @db.Text
  content   String?   @db.Text
  fileUrl   String?   @db.Text
  checksum  String?   @db.Text
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id        String    @id @default(cuid()) @db.Text
  userId    String    @db.Text
  user      User      @relation(fields: [userId], references: [id])
  topic     String    @db.Text
  sourceId  String?   @db.Text
  source    Source?   @relation(fields: [sourceId], references: [id])
  status    String    @default("active") @db.Text
  summary   Json?
  teachingMode String @default("warm") @db.Text
  roadmap     Roadmap?
  messages    Message[]
  checkpoints Checkpoint[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Roadmap {
  id        String  @id @default(cuid()) @db.Text
  sessionId String  @unique @db.Text
  session   Session @relation(fields: [sessionId], references: [id])
  nodes     Node[]
  version   Int     @default(1)
}

model Node {
  id           String   @id @default(cuid()) @db.Text
  roadmapId    String   @db.Text
  roadmap      Roadmap  @relation(fields: [roadmapId], references: [id])
  index        Int
  title        String   @db.Text
  description  String   @db.Text
  status       String   @default("not-started") @db.Text
  masteryScore Int      @default(0)
  reviewLog    Json?
  masteredAt   DateTime?
}

model Message {
  id        String   @id @default(cuid()) @db.Text
  sessionId String   @db.Text
  session   Session  @relation(fields: [sessionId], references: [id])
  role      String   @db.Text
  type      String   @db.Text
  content   String   @db.Text
  status    String   @default("completed") @db.Text
  metadata  Json?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Checkpoint {
  id        String   @id @default(cuid()) @db.Text
  sessionId String   @db.Text
  session   Session  @relation(fields: [sessionId], references: [id])
  graphNode String   @db.Text
  state     Json
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model LearnerProfile {
  id                   String   @id @default(cuid()) @db.Text
  userId               String   @unique @db.Text
  user                 User     @relation(fields: [userId], references: [id])
  learningStyle        Json?
  strengths            Json?
  weaknesses           Json?
  misconceptionPatterns Json?
  sessionsSummary      Json?
  updatedAt            DateTime @updatedAt
}
