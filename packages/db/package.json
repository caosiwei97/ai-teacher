{
  "name": "@ai-teacher/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
