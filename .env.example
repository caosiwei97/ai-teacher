# AI Teacher 环境变量配置
# 复制此文件为 .env 并填入实际值

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/ai_teacher

# Redis (Docker)
REDIS_URL=redis://localhost:26379

# MinIO (Docker)
MINIO_ENDPOINT=localhost
MINIO_PORT=29000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-teacher

# LLM (DeepSeek OpenAI 兼容接口)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com

# Web
WEB_PORT=38421

# API Server (Hono)
SERVER_PORT=38422

# Worker (BullMQ)
WORKER_PORT=38423

# Next.js frontend — API server URL (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:38422

# Judge0 (代码执行沙箱)
JUDGE0_URL=http://localhost:2358
