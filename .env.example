# AI Teacher 环境变量配置
# 复制此文件为 .env 并填入实际值

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/ai_teacher

# Redis (Docker)
REDIS_URL=redis://localhost:26379

# MinIO (Docker)
MINIO_ENDPOINT=localhost
MINIO_PORT=29000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-teacher

# LLM (DeepSeek OpenAI 兼容接口)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com

# Embedding (智谱 GLM embedding-3, OpenAI 兼容端点, 迭代 009 RAG)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024

# Web
WEB_PORT=38421

# API Server (Hono)
SERVER_PORT=38422

# Worker (BullMQ)
WORKER_PORT=38423

# Vite frontend — API server URL (used by browser)
VITE_API_URL=http://localhost:38422

# OpenSandbox (代码执行沙箱)
OPENSANDBOX_URL=http://localhost:2358

# LLM API Key 加密密钥 (32 字节 hex，用于加密用户 API Key)
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LLM_ENCRYPTION_KEY=
