{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ai-teacher/shared": [
        "../../packages/shared/src"
      ],
      "@ai-teacher/db": [
        "../../packages/db/src"
      ]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
