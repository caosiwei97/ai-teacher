{
  "name": "ai-teacher",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "pnpm": ">=10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:web": "pnpm --filter @ai-teacher/web dev",
    "dev:server": "pnpm --filter @ai-teacher/server dev",
    "dev:worker": "pnpm --filter @ai-teacher/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @ai-teacher/db generate",
    "db:migrate": "pnpm --filter @ai-teacher/db migrate",
    "db:seed": "pnpm --filter @ai-teacher/db seed",
    "db:clean": "pnpm --filter @ai-teacher/db clean",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup:env": "node scripts/setup-env.mjs",
    "bootstrap": "run-s setup:env docker:up db:generate db:migrate",
    "dev": "node scripts/kill-ports.mjs && pnpm db:generate && run-p dev:*",
    "fresh": "rm -rf apps/web/dist && node scripts/kill-ports.mjs && pnpm db:generate && run-p dev:*",
    "start": "node scripts/kill-ports.mjs && pnpm db:generate && run-p start:*",
    "start:web": "pnpm --filter @ai-teacher/web start",
    "start:server": "pnpm --filter @ai-teacher/server start",
    "start:worker": "pnpm --filter @ai-teacher/worker start",
    "prod": "run-s build start",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:docs": "node scripts/check-doc-consistency.mjs",
    "check:deps": "node scripts/check-deps.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@playwright/test",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "youtube-dl-exec"
    ]
  },
  "lint-staged": {
    "*.{md,css,json,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.179",
    "@hono/zod-validator": "^0.8.0",
    "ai": "^6.0.177",
    "dotenv-cli": "^11.0.0",
    "zod": "^4.4.3"
  }
}
